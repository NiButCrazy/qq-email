{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QQ 邮箱",
  "version": "0.2.0",
  "identifier": "com.qq-mail.desktop",
  "build": {},
  "app": {
    "windows": [
      {
        "create": false,
        "title": "QQ 邮箱",
        "visible": false,
        "label": "main",
        "url": "https://wx.mail.qq.com",
        "width": 1360,
        "height": 880,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    },
    "resources": [
      "assets/*",
      "extensions"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mailto"]
      }
    }
  }
}
